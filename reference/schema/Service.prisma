model Service {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  duration    Int?
  price       Float?

  availableAtBranches ServicesToBranches[]
  availableAtUnits    BusinessUnitsToServices[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("services")
}
