/// Composite type DocumentTemplateBody has been converted to a related model
/// since PostgreSQL does not support Prisma composite types.
model DocumentTemplateBody {
  id         Int                      @id @default(autoincrement())
  language   DocumentTemplateLanguage
  body       String
  templateId Int

  template DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("document_template_bodies")
}

model DocumentTemplate {
  id Int @id @default(autoincrement())

  type             DocumentTemplateType
  name             String
  body             DocumentTemplateBody[]
  businessBranchId Int
  active           Boolean                @default(true)

  businessBranch BusinessBranch @relation(fields: [businessBranchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
