model Supplier {
  id Int @id @default(autoincrement())

  name        String
  email       String?
  phone       String?
  phoneNumber String?
  category    String?
  address     String?
  status      String? @default("ACTIVE")

  businessBranchId Int
  businessBranch   BusinessBranch @relation(fields: [businessBranchId], references: [id])

  products Product[]

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("suppliers")
}
