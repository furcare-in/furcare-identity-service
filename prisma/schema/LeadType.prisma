model LeadType {
  id Int @id @default(autoincrement())
  
  name        String
  sources     String[]
  description String?
  
  businessBranchId Int 
  businessBranch   BusinessBranch @relation(fields: [businessBranchId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lead_types")
}
