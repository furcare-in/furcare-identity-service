model PortalPost {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  content          String
  tags             String[]
  category         String?
  likes            Int      @default(0)
  views            Int      @default(0)
  likedBy          String[] @db.ObjectId
  
  authorId         String   @db.ObjectId
  author           Staff    @relation(fields: [authorId], references: [id])
  
  businessBranchId String?   @db.ObjectId
  businessBranch   BusinessBranch? @relation(fields: [businessBranchId], references: [id])
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("portal_posts")
}
