// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum SterilizationStatus {
  intact
  sterilized
  unsure
}

enum AnimalGender {
  male
  female
}

enum AppointmentType {
  Regular
  Virtual
}

enum RecurrenceType {
  DoesNotRepeat @map("Does not repeat")
  EveryWeekday  @map("Every weekday")
}
