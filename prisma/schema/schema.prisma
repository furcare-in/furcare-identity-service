// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
  binaryTargets   = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-arm64-openssl-1.1.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SterilizationStatus {
  intact
  sterilized
  unsure
}

enum AnimalGender {
  male
  female
}

enum AppointmentType {
  Regular
  Virtual
}

enum RecurrenceType {
  DoesNotRepeat @map("Does not repeat")
  EveryWeekday  @map("Every weekday")
}
