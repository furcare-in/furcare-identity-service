model Service {
  id Int @id @default(autoincrement())
  name         String
  description  String?
  duration     Int?
  price        Float?
  isCustom     Boolean  @default(false)
  branchId     String?  
  departmentId Int?   

  department   Department? @relation(fields: [departmentId], references: [id])
  roomServices RoomService[]

  availableAtBranches ServicesToBranches[]
  availableAtUnits    BusinessUnitsToServices[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
  @@index([branchId])
  @@map("services")
}
