model Group {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name             String
  description      String?
  businessBranchId String          @db.ObjectId
  active           Boolean         @default(true)
  resources        GroupsToStaff[]
  schedules        StaffSchedule[]
  shiftStartTime   String?
  shiftEndTime     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("groups")
}

model GroupsToStaff {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  groupId      String @db.ObjectId
  staffId      String @db.ObjectId
  groupDetails Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  staffDetails Staff  @relation(fields: [staffId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, groupId])
  @@map("groups_to_staff")
}
