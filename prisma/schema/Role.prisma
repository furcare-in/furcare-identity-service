enum Action {
  create
  read
  update
  delete
  write
}

enum Resource {
  document
  animalClass
  diagnosticIntegration
}



enum AccessLevel {
  businessUnit
  businessBranch
}

model Role {
  id Int @id @default(autoincrement())

  name        String
  permissions Json[]

  businessUnitId Int          
  businessUnit     BusinessUnit    @relation(fields: [businessUnitId], references: [id])
  accessLevel      AccessLevel
  active           Boolean         @default(true)
  businessBranchId Int?         
  businessBranch   BusinessBranch? @relation(fields: [businessBranchId], references: [id])
  isStaff          Boolean         @default(true)

  staff StaffToRoles[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}
