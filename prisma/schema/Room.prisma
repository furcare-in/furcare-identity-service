model Room {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  businessBranchId String   @db.ObjectId
  roomServices     RoomService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([businessBranchId])
  @@map("rooms")
}
