model RoomService {
  id Int @id @default(autoincrement())
  roomId Int   
  serviceId Int   
  price     Float
  duration  Int
  
  room      Room     @relation(fields: [roomId], references: [id])
  service   Service  @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId])
  @@index([serviceId])
  @@map("room_services")
}
