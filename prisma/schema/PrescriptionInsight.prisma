model PrescriptionInsight {
  id Int @id @default(autoincrement())
  
  medicineId Int?  
  masterMedicine   MasterMedicine? @relation(fields: [medicineId], references: [id])

  genericName      String
  brandName        String?
  
  doctorId         String?  
  visitId          String?  
  
  strength         String?
  form             String?
  minDoseMgPerKg   Float?
  maxDoseMgPerKg   Float?
  doseUnit         String?
  route            String?
  frequency        String?
  species          String?

  businessBranchId String   
  
  prescribedAt     DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([genericName])
  @@index([doctorId])
  @@index([businessBranchId])
  @@index([prescribedAt])
  @@map("prescription_insights")
}

