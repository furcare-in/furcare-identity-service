model BusinessBranch {
  id Int @id @default(autoincrement())

  businessUnitId Int                    
  name                   String
  type                   String
  practice               String
  currency               String
  addressLine1           String
  addressLine2           String
  country                String
  state                  String
  city                   String
  postalCode             String
  services               ServicesToBranches[]
  departments            DepartmentsToBranches[]
  animalClasses          BranchesToAnimalClasses[]
  appointmentSlots       AppointmentSlot[]
  diagnosticIntegrations DiagnosticIntegration[]
  access                 Role[]
  staff                  Staff[]
  staffAssignments       StaffToBranches[]
  reports                Report[]
  active                 Boolean                   @default(true)
  supplies               Supply[]
  products               Product[]
  suppliers              Supplier[]
  visits                 Visit[]
  clients                Client[]
  businessUnit           BusinessUnit              @relation(fields: [businessUnitId], references: [id])
  contentLibrary         Content[]
  documentTemplates      DocumentTemplate[]
  leadTypes              LeadType[]
  portalPosts            PortalPost[]
  vaccinationStatuses    VaccinationStatus[]
  locations              LocationsToBranches[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("business_branches")
}

model ServicesToBranches {
  id Int @id @default(autoincrement())
  serviceId Int         
  branchId Int         
  basePrice      Int
  active         Boolean        @default(true)
  serviceDetails Service        @relation(fields: [serviceId], references: [id])
  branchDetails  BusinessBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, branchId])
  @@map("services_to_branches")
}

model DepartmentsToBranches {
  id Int @id @default(autoincrement())
  departmentId Int         
  branchId Int         
  active            Boolean        @default(true)
  departmentDetails Department     @relation(fields: [departmentId], references: [id])
  branchDetails     BusinessBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([departmentId, branchId])
  @@map("departments_to_branches")
}

model BranchesToAnimalClasses {
  id Int @id @default(autoincrement())
  branchId Int         
  animalClassId Int?        
  branchDetails      BusinessBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  animalClassDetails AnimalClass?   @relation(fields: [animalClassId], references: [id], onDelete: SetNull)
  active             Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, animalClassId])
  @@map("animal_classes_to_branches")
}
