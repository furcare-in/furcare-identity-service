model Department {
  id Int @id @default(autoincrement())
  name String

  services                 Service[]
  availableAtBusinessBranches DepartmentsToBranches[]
  availableAtBusinessUnits    BusinessUnitsToDepartments[]
  appointmentSlots            AppointmentSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}
