model Department {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  services                 Service[]
  availableAtBusinessBranches DepartmentsToBranches[]
  availableAtBusinessUnits    BusinessUnitsToDepartments[]
  appointmentSlots            AppointmentSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}
