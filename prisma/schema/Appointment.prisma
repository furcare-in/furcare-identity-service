model Appointment {
  id Int @id @default(autoincrement())

  clientId         String
  name             String
  appointmentType  String
  appointmentDate  String
  appointmentTime  String
  doctorId         String?
  comment          String?
  branchId         String
  departmentId     String?
  petId            String[]
  petNames         String[]
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("appointments")
}
