enum ReportType {
  appointments
  admin
  client_and_patient
  inventory
  communication
  visits
  leads
}

enum ReportFrequency {
  day
  week
  month
}

model Report {
  id Int @id @default(autoincrement())

  name                 String
  type                 ReportType
  fields               String[]
  generateInBackground Boolean
  frequency            ReportFrequency?
  businessBranchId Int?          
  businessBranch       BusinessBranch?  @relation(fields: [businessBranchId], references: [id])
  businessUnitId Int?          
  businessUnit         BusinessUnit?    @relation(fields: [businessUnitId], references: [id])

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reports")
}
