model MedicineObservation {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId

  medicineId       String?  @db.ObjectId // Optional, in case it's a completely new generic
  masterMedicine   MasterMedicine? @relation(fields: [medicineId], references: [id])

  genericName      String   // To link even if medicineId is unknown

  fieldName        String   // e.g., "route", "form", "strength"
  fieldValue       String   // e.g., "oral", "chewable tablet"

  source           String   // "doctor", "inventory"
  sourceId         String?  // doctorId or productId

  confidence       Float    // 0.0 to 1.0 (e.g. 0.75 for doctor, 0.60 for inventory)
  conflict         Boolean  @default(false)
  needsReview      Boolean  @default(false)

  businessBranchId String?  @db.ObjectId

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([medicineId])
  @@index([genericName])
  @@index([fieldName])
  @@index([source])
  @@map("medicine_observations")
}
