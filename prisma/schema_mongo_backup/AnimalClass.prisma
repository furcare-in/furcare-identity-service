model AnimalClass {
  id          String                    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  breeds      String[]
  availableAt BranchesToAnimalClasses[]
  contents    Content[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  registeredPets Pet[]

  @@map("animal_classes")
}
