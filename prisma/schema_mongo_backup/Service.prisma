model Service {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  duration    Int?
  price       Float?

  availableAtBranches ServicesToBranches[]
  availableAtUnits    BusinessUnitsToServices[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("services")
}
