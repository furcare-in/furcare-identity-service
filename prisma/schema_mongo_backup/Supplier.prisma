model Supplier {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name    String
  email   String?
  phone   String?
  phoneNumber String?
  category String?
  address String?
  status  String? @default("ACTIVE")

  businessBranchId String         @db.ObjectId
  businessBranch   BusinessBranch @relation(fields: [businessBranchId], references: [id])

  products Product[]

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("suppliers")
}
